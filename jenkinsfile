pipeline {
    agent any

    environment {
        IMAGE_NAME = "prt-ci-cd-demo"
    }

    stages {

        stage('Clone Repository') {
            steps {
                git url: 'https://github.com/deekshu-hub/mokshagnfile.git', branch: 'main'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t my-img ."
                }
            }
        }

        stage('Run Docker Container') {
            steps {
                script {
                    sh "docker run -itd --name m3 -p 80:80 my-img"
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline executed successfully!"
        }
        failure {
            echo "Pipeline failed!"
        }
    }
}
